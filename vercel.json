{
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/admin",
            "dest": "/public/admin.html"
        },
        {
            "src": "/customer",
            "dest": "/public/customer.html"
        },
        {
            "src": "/waiter",
            "dest": "/public/waiter.html"
        },
        {
            "src": "/kitchen",
            "dest": "/public/kitchen.html"
        },
        {
            "src": "/state\\.js",
            "dest": "/public/state.js"
        },
        {
            "src": "/favicon\\.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/(.*\\.(?:css|js|ico|png|jpg|jpeg|svg|gif|woff|woff2|ttf|eot))$",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
